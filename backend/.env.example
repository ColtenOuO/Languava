# Copy this file to backend/.env and adjust as needed.
# Hostnames `postgres` / `redis` resolve via the docker compose network.

# --- API ---
API_PORT=8000
WEB_CONCURRENCY=2

# --- Database (Postgres) ---
POSTGRES_USER=languava
POSTGRES_PASSWORD=languava
POSTGRES_DB=languava
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg://languava:languava@postgres:5432/languava

# --- Redis ---
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0
